---
import 'katex/dist/katex.min.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  active?: 'inicio' | 'teoria' | 'exposiciones';
}
const { title, description = 'Guía de estudio interactiva de Computación Visual — UNMSM. Teoría, fórmulas, ejercicios y cuestionarios.', active } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0f1a" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a href="/" class="brand">
          <span class="logo">CV</span>
          <span>Repaso<span class="grad">CV</span></span>
        </a>
        <nav class="nav">
          <a href="/" class={active === 'inicio' ? 'active' : ''}>Inicio</a>
          <a href="/teoria" class={active === 'teoria' ? 'active' : ''}>Teoría</a>
          <a href="/exposiciones" class={active === 'exposiciones' ? 'active' : ''}>Exposiciones</a>
          <a href="https://github.com/steveenmaque/RepasoCV" class="hide-sm" target="_blank" rel="noopener">GitHub</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container inner">
        <span>RepasoCV · Computación Visual · Ciclo 5 · UNMSM — FISI</span>
        <span>Material de repaso para el examen final</span>
      </div>
    </footer>
  </body>
</html>
