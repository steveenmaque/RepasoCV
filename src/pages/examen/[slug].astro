---
import Base from '../../layouts/Base.astro';
import VerdaderoFalso from '../../components/VerdaderoFalso.astro';
import Quiz from '../../components/Quiz.astro';
import Ejercicios from '../../components/Ejercicios.astro';
import { examenes, porExamenSlug } from '../../data';

export function getStaticPaths() {
  return examenes.map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const ex = porExamenSlug[slug!];
const puntosVF = ex.verdaderoFalso.length; // 0.5 pts c/u aprox. como el parcial real
---

<Base title={`${ex.titulo} — RepasoCV`} description={ex.descripcion} active="examenes">
  <section class="topic-hero" style={`--_c:${ex.color}`}>
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Inicio</a> ·
        <a href="/examenes">Exámenes</a> ·
        <span>{ex.titulo}</span>
      </div>
      <span class="pill examenes">{ex.codigo}{ex.duracion ? ` · ${ex.duracion}` : ''}</span>
      <h1>{ex.titulo}</h1>
      <p class="sub">{ex.descripcion}</p>
      <p class="fuente-hero">📖 Basado en: <b>{ex.fuente}</b></p>
      <div class="temario">
        {ex.temas.map((t) => <span class="tag">{t}</span>)}
      </div>
    </div>
  </section>

  <div class="container layout">
    <aside class="toc">
      <div class="toc-title">Partes del examen</div>
      {ex.verdaderoFalso.length > 0 && <a href="#vf">I. Verdadero / Falso</a>}
      {ex.opcionMultiple.length > 0 && <a href="#mc">II. Opción múltiple</a>}
      {ex.aplicacion.length > 0 && <a href="#app">III. Aplicación</a>}
    </aside>

    <div class="content">
      {
        ex.verdaderoFalso.length > 0 && (
          <>
            <h2 class="block-title" id="vf">
              <span class="ico">✅</span> Parte I · Verdadero / Falso
              <span class="pts">({puntosVF} enunciados · teoría)</span>
            </h2>
            <p style="color:var(--text-mute);font-size:0.9rem;margin-top:-6px;">
              Cada enunciado vale lo mismo. Justifica mentalmente antes de marcar; una sola palabra
              cambia el valor de verdad.
            </p>
            <VerdaderoFalso items={ex.verdaderoFalso} id={`vf-${ex.slug}`} />
          </>
        )
      }

      {
        ex.opcionMultiple.length > 0 && (
          <>
            <h2 class="block-title" id="mc">
              <span class="ico">🧠</span> Parte II · Opción múltiple
              <span class="pts">({ex.opcionMultiple.length} preguntas)</span>
            </h2>
            <Quiz preguntas={ex.opcionMultiple} id={`mc-${ex.slug}`} />
          </>
        )
      }

      {
        ex.aplicacion.length > 0 && (
          <>
            <h2 class="block-title" id="app">
              <span class="ico">✏️</span> Parte III · Ejercicios de aplicación
              <span class="pts">({ex.aplicacion.length} problemas)</span>
            </h2>
            <Ejercicios ejercicios={ex.aplicacion} />
          </>
        )
      }
    </div>
  </div>
</Base>
