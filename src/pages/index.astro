---
import Base from '../layouts/Base.astro';
import TemaCard from '../components/TemaCard.astro';
import { teoria, exposiciones, stats } from '../data';
---

<Base title="RepasoCV — Guía de estudio de Computación Visual" active="inicio">
  <section class="hero container">
    <span class="eyebrow">Computación Visual · UNMSM · Examen Final</span>
    <h1>Repasa <span class="grad">toda la Computación Visual</span> en un solo lugar</h1>
    <p>
      Teoría condensada, fórmulas clave, imágenes, ejercicios de nivel medio–difícil y cuestionarios
      interactivos por cada tema de <b>Teoría</b> y de las <b>Exposiciones</b> del curso.
    </p>
    <div class="cta">
      <a class="btn btn-primary" href="/teoria">Empezar por Teoría</a>
      <a class="btn btn-ghost" href="/exposiciones">Ver Exposiciones</a>
    </div>

    <div class="stats">
      <div class="stat"><div class="n">{stats.temas}</div><div class="l">Temas</div></div>
      <div class="stat"><div class="n">{stats.preguntas}</div><div class="l">Preguntas</div></div>
      <div class="stat"><div class="n">{stats.ejercicios}</div><div class="l">Ejercicios</div></div>
      <div class="stat"><div class="n">{stats.formulas}</div><div class="l">Fórmulas</div></div>
    </div>
  </section>

  <section class="section container">
    <div class="section-head">
      <span class="pill teoria">Teoría</span>
      <h2>Sesiones de teoría</h2>
    </div>
    <div class="grid">
      {teoria.map((t) => <TemaCard tema={t} />)}
    </div>
  </section>

  <section class="section container">
    <div class="section-head">
      <span class="pill expos">Exposiciones</span>
      <h2>Temas de las exposiciones</h2>
    </div>
    <div class="grid">
      {exposiciones.map((t) => <TemaCard tema={t} />)}
    </div>
  </section>
</Base>
