---
import Base from '../layouts/Base.astro';
import TemaCard from '../components/TemaCard.astro';
import ExamenCard from '../components/ExamenCard.astro';
import { teoria, exposiciones, examenes, stats } from '../data';
---

<Base title="RepasoCV — Guía de estudio de Computación Visual" active="inicio">
  <section class="hero container">
    <span class="eyebrow">Computación Visual · UNMSM · Examen Final</span>
    <h1>Repasa <span class="grad">toda la Computación Visual</span> en un solo lugar</h1>
    <p>
      Teoría condensada, fórmulas clave, imágenes, ejercicios de nivel medio–difícil, cuestionarios
      interactivos y <b>simulacros de examen</b> con el mismo formato del curso: Verdadero/Falso
      teórico y ejercicios de aplicación con solución.
    </p>
    <div class="cta">
      <a class="btn btn-primary" href="/examenes">Practicar Exámenes</a>
      <a class="btn btn-ghost" href="/teoria">Empezar por Teoría</a>
    </div>

    <div class="stats">
      <div class="stat"><div class="n">{stats.temas}</div><div class="l">Temas</div></div>
      <div class="stat"><div class="n">{stats.examenes}</div><div class="l">Exámenes</div></div>
      <div class="stat"><div class="n">{stats.ejercicios + stats.preguntasExamen}</div><div class="l">Ejercicios y preguntas</div></div>
      <div class="stat"><div class="n">{stats.formulas}</div><div class="l">Fórmulas</div></div>
    </div>
  </section>

  <section class="section container">
    <div class="section-head">
      <span class="pill examenes">Exámenes</span>
      <h2>Simulacros para el examen final</h2>
    </div>
    <p style="color:var(--text-dim);max-width:720px;margin:-6px 0 22px;">
      Con el <b>formato real del profesor</b>: gran bloque de <b>Verdadero/Falso</b> teórico +
      <b>ejercicios de aplicación</b> (obtener matrices, evaluar curvas, calcular iluminación) con
      solución paso a paso. Inspirados en libros clásicos de Computación Gráfica.
    </p>
    <div class="grid">
      {examenes.map((e) => <ExamenCard examen={e} />)}
    </div>
  </section>

  <section class="section container">
    <div class="section-head">
      <span class="pill teoria">Teoría</span>
      <h2>Sesiones de teoría</h2>
    </div>
    <div class="grid">
      {teoria.map((t) => <TemaCard tema={t} />)}
    </div>
  </section>

  <section class="section container">
    <div class="section-head">
      <span class="pill expos">Exposiciones</span>
      <h2>Temas de las exposiciones</h2>
    </div>
    <div class="grid">
      {exposiciones.map((t) => <TemaCard tema={t} />)}
    </div>
  </section>
</Base>
